rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid))
             .data.role == 'super_admin';
    }

    function hasPermission(resource, operation) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && 'permissions' in userDoc.data
          && resource in userDoc.data.permissions
          && operation in userDoc.data.permissions[resource]
          && userDoc.data.permissions[resource][operation] == true;
    }

    // --- Members Collection ---
    match /members/{memberId} {
      allow read: if isSuperAdmin() || hasPermission('members', 'read');
      allow create: if isSuperAdmin() || hasPermission('members', 'create');
      allow update: if isSuperAdmin() || hasPermission('members', 'update');
      allow delete: if isSuperAdmin() || hasPermission('members', 'delete');
    }

    // --- Transactions Collection ---
    match /transactions/{transactionId} {
      // Anyone with transactions.read (or super admin) may read any transaction document.
      // Do not use allow read, write: if request.auth != null — that exposes delete to every user.
      allow read: if isSuperAdmin() || hasPermission('transactions', 'read');
      allow create: if isSuperAdmin() || hasPermission('transactions', 'create');
      allow update: if isSuperAdmin() || hasPermission('transactions', 'update');
      allow delete: if isSuperAdmin() || hasPermission('transactions', 'delete');
    }

    // --- Roles Collection ---
    match /roles/{roleId} {
      allow read: if isSuperAdmin()
                 || hasPermission('team', 'update')
                 || hasPermission('team', 'create');
      allow write: if isSuperAdmin();
    }

    // --- Users Collection ---
    match /users/{userId} {
      // super_admin can read any user doc
      allow get: if request.auth.uid == userId || isSuperAdmin();
      allow list: if isSuperAdmin() || hasPermission('team', 'read');
      allow create: if request.auth.uid == userId
                   || isSuperAdmin()
                   || hasPermission('team', 'create');
      allow update: if (request.auth.uid == userId
                       && !('role' in request.resource.data)
                       && !('permissions' in request.resource.data))
                   || isSuperAdmin()
                   || hasPermission('team', 'update');
      allow delete: if (isSuperAdmin() || hasPermission('team', 'delete'))
                   && request.auth.uid != userId;
    }

    // Teams + members sub-collection
    match /teams/{teamId} {
      allow read, write: if isSuperAdmin();

      match /members/{memberId} {
        allow read, write: if isSuperAdmin();
      }
    }

    // --- Logs Collection ---
    match /{path=**}/logs/{logId} {
      allow create: if request.auth != null
                   && request.auth.uid == request.resource.data.actorId;
      allow read: if isSuperAdmin()
                 || (hasPermission('team', 'read')
                    && resource.data.actorId == request.auth.uid);
      allow update, delete: if false;
    }

    // --- Dashboard Summary ---
    match /dashboard/summary {
      allow read: if isSuperAdmin() || hasPermission('dashboard', 'read');
    }
  }
}
